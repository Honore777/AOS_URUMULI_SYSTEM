# Application Configuration
SECRET_KEY=your-secret-key-here-generate-long-random-string
FLASK_ENV=production
LOG_LEVEL=INFO

# Database Configuration
POSTGRES_USER=urumuli_user
POSTGRES_PASSWORD=your-strong-database-password-here
POSTGRES_DB=urumuli_prod
DATABASE_URL=postgresql://urumuli_user:your-strong-database-password-here@db:5432/urumuli_prod

# Redis Configuration
REDIS_PASSWORD=your-strong-redis-password-here

# Brevo Email Configuration
BREVO_API_KEY=your-brevo-api-key-here
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=Urumuli Smart System

# Admin User (change this after first login)
ADMIN_PASSWORD=your-admin-password-here

# Database Pool Configuration
SQLALCHEMY_POOL_SIZE=7
SQLALCHEMY_MAX_OVERFLOW=10
SQLALCHEMY_POOL_TIMEOUT=35
SQLALCHEMY_POOL_RECYCLE=400

# Domain Configuration (for SSL)
DOMAIN=yourdomain.com

# Monitoring Configuration (optional)
ENABLE_MONITORING=false
PROMETHEUS_RETENTION=15d
